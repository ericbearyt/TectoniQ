  "sections": [
    {
      "id": "s0",
      "header": "CHIEF COMPLAINT",
      "page": 1,
      "content": "Patient presents with persistent fatigue, shortness of breath, and bilateral lower extremity edema for the past 3 weeks.",
      "duplicate_of": null,
      "keywords": [
        "fatigue",
        "edema",
        "shortness"
      ]
    },
    {
      "id": "s1",
      "header": "PAST MEDICAL HISTORY",
      "page": 2,
      "content": "History of hypertension diagnosed in 2018. Prior myocardial infarction in 2021. Former smoker, resolved 2019. Type 2 diabetes mellitus.",
      "duplicate_of": null,
      "keywords": [
        "hypertension",
        "myocardial infarction",
        "diabetes mellitus",
        "smoking"
      ]
    },
    {
      "id": "s2",
      "header": "MEDICATIONS",
      "page": 3,
      "content": "Current medications include Metformin 500mg twice daily, Lisinopril 10mg daily, Atorvastatin 40mg nightly, and Aspirin 81mg daily.",
      "duplicate_of": null,
      "keywords": [
        "metformin",
        "lisinopril",
        "atorvastatin",
        "aspirin"
      ]
    },
    {
      "id": "s3",
      "header": "ASSESSMENT",
      "page": 4,
      "content": "Active heart failure exacerbation likely secondary to medication non-compliance. Hypertension poorly controlled. Diabetes mellitus stable. Atrial fibrillation, new onset.",
      "duplicate_of": null,
      "keywords": [
        "heart failure",
        "hypertension",
        "diabetes mellitus",
        "atrial fibrillation"
      ]
    },
    {
      "id": "s4",
      "header": "PLAN",
      "page": 5,
      "content": "Initiate Furosemide 40mg IV twice daily. Cardiology consult for atrial fibrillation. Repeat echocardiogram. Strict sodium restriction. Adjust Lisinopril to 20mg daily.",
      "duplicate_of": null,
      "keywords": [
        "furosemide",
        "cardiology",
        "echocardiogram",
        "lisinopril"
      ]
    },
    {
      "id": "s5",
      "header": "LABS",
      "page": 6,
      "content": "BNP 980 pg/mL (elevated). HbA1c 7.4%. Serum creatinine 1.3 mg/dL. Potassium 3.8 mEq/L. Hemoglobin 11.2 g/dL.",
      "duplicate_of": null,
      "keywords": [
        "bnp",
        "hba1c",
        "creatinine",
        "potassium",
        "hemoglobin"
      ]
    },
    {
      "id": "s6",
      "header": "ASSESSMENT",
      "page": 7,
      "content": "Reassessment 48 hours post-admission. Improved respiratory status. Hypertension now controlled. Heart failure symptoms improving with diuresis.",
      "duplicate_of": "s3",
      "keywords": [
        "hypertension",
        "heart failure",
        "diuresis"
      ]
    }
  ],
